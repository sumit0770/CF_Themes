{
  "manifest_version": 3,
  "name": "CF Theme Pro",
  "version": "1.1.0",
  "permissions": ["storage"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["themes.js", "content.js"]
    }
  ],
  "icons": {
    "192": "/assets/android-chrome-192x192.png",
    "512": "/assets/android-chrome-512x512.png"
  }
}